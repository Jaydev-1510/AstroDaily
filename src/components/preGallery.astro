---
import Icon from "./icons.astro";
import { database } from "@lib/database";

interface APODItem {
  date: string;
  title: string | null;
  url: string | null;
  hdurl: string | null
}

const { data: rawItems } = await database
  .from("APODs")
  .select("date, title, url, hdurl")
  .order("date", { ascending: false })
  .limit(40);

const galleryItems = rawItems?.filter((item) => item.url && /\.(jpg|jpeg|png|webp|gif|avif)$/i.test(item.url)).slice(0, 20) ?? [];
---

<section id="gallery-preview" aria-labelledby="gallery-heading" class="w-full max-w-7xl md:py-32 hidden md:flex flex-col gap-16 mx-auto" >
  <header class="text-center">
    <h2 id="gallery-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-zinc-100">
      Gallery
    </h2>
  </header>

  <div class="relative max-h-screen overflow-hidden after:content-[''] after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:right-0 after:h-40 after:bg-linear-to-t after:from-black after:to-transparent">
    <div class="columns-1 md:columns-2 lg:columns-3 xl:columns-4 gap-8 space-y-8 ">
      {galleryItems?.map((item:APODItem) => {
        const encoded = item.url ? encodeURIComponent(item.url) : "";
        const placeholder = `https://wsrv.nl/?url=${encoded}&w=20&output=webp&q=1&blur=3`;
        const full = `https://wsrv.nl/?url=${encoded}&w=800&output=webp&q=80`;
        return (
          <article class="break-inside-avoid">
            <figure class="group relative overflow-hidden rounded-3xl bg-white/5 transition-all duration-500 hover:bg-white/10" >
              <img src={placeholder} data-src={full} width={800} height={1000} alt={item.title} loading="lazy" class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03] blur-xl scale-110"
              onload="
              if (this.dataset.src && this.src !== this.dataset.src) {
                const full = new Image();
                full.onload = () => { this.src = this.dataset.src; this.classList.remove('blur-xl', 'scale-110'); };
                full.src = this.dataset.src;
              }" />
              <figcaption class="absolute inset-0 flex items-end bg-linear-to-t from-black/80 via-black/30 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" >
                <div class="p-4 flex flex-col gap-1 translate-y-4 transition-transform duration-500 group-hover:translate-y-0">
                  <span class="text-xs font-semibold uppercase tracking-[0.3em] text-white/70">
                    {item.date}
                  </span>
                  <h3 class="text-white text-lg font-medium leading-tight line-clamp-1">
                    {item.title}
                  </h3>
                </div>
              </figcaption>
            </figure>
          </article>
        );
      })}
    </div>
  </div>
  <div class="flex justify-center">
    <a href="/gallery" class="group flex items-center justify-center gap-2 rounded-3xl bg-white px-8 py-4 text-sm font-semibold text-black transition-transform active:scale-95 hover:bg-zinc-200" >
      View full gallery
      <Icon glyph="arrow-right" class="group-hover:translate-x-1 transition-transform duration-300"/>
    </a>
  </div>
</section>

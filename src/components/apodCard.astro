---
import { Image } from "astro:assets";
const { Apod } = Astro.props;
---

<div
  class="relative min-h-screen bg-[#050505] text-zinc-300 selection:bg-white selection:text-black"
>
  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute -top-[25%] -left-[10%] w-[70%] h-[70%] bg-zinc-500/10 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute top-[20%] -right-[10%] w-[60%] h-[60%] bg-zinc-500/5 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-24">
    <div class="flex flex-col items-center">
      <header
        class="flex flex-col items-center mb-12 animate-in fade-in slide-in-from-bottom-4 duration-1000"
      >
        <div class="flex items-center gap-3 mb-6">
          <span class="h-px w-8 bg-white/20"></span>
          <span
            class="text-[11px] font-bold tracking-[0.3em] uppercase text-zinc-500"
          >
            {Apod?.date}
          </span>
          <span class="h-px w-8 bg-white/20"></span>
        </div>

        <h1
          class="font-sans text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white text-center leading-[1.1] max-w-4xl"
        >
          {Apod?.title}
        </h1>
      </header>

      <figure
        class="w-full relative group mb-24 animate-in fade-in zoom-in-95 duration-1000 delay-200"
      >
        <div
          class="absolute inset-0 bg-white/5 blur-3xl rounded-2xl opacity-20 group-hover:opacity-30 transition-opacity"
        >
        </div>
        <Image
          width={1200}
          loading="eager"
          src={Apod?.hdurl ||
            "https://astro.build/assets/press/astro-logo-light-gradient.png"}
          alt={Apod?.title || "NASA"}
          class="relative w-full object-cover rounded-3xl md:rounded-[2.5rem] border border-white/10 shadow-2xl shadow-black"
        />

        <div
          class="absolute md:bottom-6 md:right-8 bottom-3 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 md:block"
        >
          <p
            class="text-[10px] tracking-widest uppercase text-white/50 bg-black/40 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/10"
          >
            &copy; {Apod?.copyright || "NASA"}
          </p>
        </div>
      </figure>

      <div
        class="grid grid-cols-1 lg:grid-cols-[1fr_2px_1fr] gap-12 lg:gap-20 items-start max-w-5xl"
      >
        <article class="prose prose-invert prose-zinc lg:prose-lg">
          <h2 class="text-white font-medium text-lg mb-4 tracking-tight">
            Explanation
          </h2>
          <p class="text-zinc-400 leading-relaxed text-balance">
            {Apod?.explanation}
          </p>
        </article>

        <div
          class="hidden lg:block self-stretch bg-linear-to-b from-transparent via-white/10 to-transparent"
        >
        </div>

        <aside class="flex flex-col gap-8 lg:sticky lg:top-32">
          <div
            class="p-6 rounded-2xl border border-white/5 bg-white/2 backdrop-blur-sm"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4"
            >
              Metadata
            </h3>
            <div class="space-y-4">
              <div
                class="flex justify-between items-center border-b border-white/5 pb-3"
              >
                <span class="text-sm text-zinc-500">Source</span>
                <span class="text-sm text-zinc-200">NASA APOD</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-zinc-500">Credit</span>
                <span class="text-sm text-zinc-200"
                  >{Apod?.copyright || "Public Domain"}</span
                >
              </div>
            </div>
          </div>

          <a
            href="/archive"
            class="group flex items-center justify-center gap-2 py-4 rounded-2xl bg-white text-black font-semibold text-sm transition-transform active:scale-95 hover:bg-zinc-200"
          >
            Browse Archive
            <svg
              class="group-hover:translate-x-2 transition-transform duration-200"
              data-testid="geist-icon"
              height="16"
              stroke-linejoin="round"
              style="color: currentcolor;"
              viewBox="0 0 16 16"
              width="16"
              ><path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M9.53033 2.21968L9 1.68935L7.93934 2.75001L8.46967 3.28034L12.4393 7.25001H1.75H1V8.75001H1.75H12.4393L8.46967 12.7197L7.93934 13.25L9 14.3107L9.53033 13.7803L14.6036 8.70711C14.9941 8.31659 14.9941 7.68342 14.6036 7.2929L9.53033 2.21968Z"
                fill="currentColor"></path></svg
            >
          </a>
        </aside>
      </div>
    </div>
  </div>
</div>

<style>
  .animate-in {
    animation-fill-mode: forwards;
  }
</style>
